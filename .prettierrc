{
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "trailingComma": "es5",
  "plugins": ["prettier-plugin-tailwindcss"],
  "overrides": [
    {
      "files": "*.json",
      "options": {
        "tabWidth": 2,
        "printWidth": 2
      }
    },
    {
      "files": "*.md",
      "options": {
        "tabWidth": 2,
        "printWidth": 80
      }
    },
    {
      "files": "*.js",
      "options": {
        "tabWidth": 2,
        "printWidth": 80
      }
    },
    {
      "files": "*.ts",
      "options": {
        "tabWidth": 2,
        "printWidth": 120,
        "singleQuote": true,
        "arrowParens": "always"
      }
    },
    {
      "files": "*.css",
      "options": {
        "tabWidth": 2,
        "printWidth": 80
      }
    },
    {
      "files": "*.scss",
      "options": {
        "tabWidth": 2,
        "printWidth": 80
      }
    },{
      "files":"*.vue",
      "options": {
        "tabWidth": 2,
        "printWidth": 80
      }
    }
  ]
}
